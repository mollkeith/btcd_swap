# PGP 链 RPC（可选，默认 https://api.elastos.io/pg）
PGP_RPC_URL=https://api.elastos.io/pg

# Gas 价格，单位 gwei（可选，默认 25）
GAS_PRICE_GWEI=25

# --- 跨链配置（PGP USDT -> BSC）---
BRIDGE_CONTRACT=0xDBB35259372B2f0cB6b85dD31761C0fB3652Fd11
BRIDGE_DEST_CHAIN_ID=56

# --- BSC ---
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_GAS_PRICE_GWEI=3

# --- 注资默认金额（可选）---
PGA_FEE_AMOUNT=0.01
BNB_FEE_AMOUNT=0.0001

# --- 归集目标（可选，默认主钱包地址）---
# COLLECT_ADDRESS=0xYOUR_COLLECT_ADDRESS

# --- 主钱包私钥（注资、归集用）---
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
